    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@cop1/domain": "workspace:*",
    "@cop1/infrastructure": "workspace:*",
    "@cop1/rules-engine": "workspace:*",
    "@cop1/llm-gateway": "workspace:*",
    "fastify": "^5.2.0",
    "@fastify/cors": "^10.0.1",
    "dotenv": "^16.4.7"
  },
  "keywords": ["cop1", "api", "rest"],
  "author": "elzinko",
  "license": "MIT"
}
